# JobPlus Docker 部署环境变量配置
# 复制此文件为 .env 并根据实际情况修改

# PostgreSQL 配置
POSTGRES_DB=jobplus
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Redis 配置
REDIS_PORT=6379

# JWT 配置
JWT_SECRET=jobplus-secret-key-must-be-at-least-256-bits-long-for-hs256-algorithm
JWT_EXPIRATION_MS=86400000

# 服务端口配置
GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
JOB_SERVICE_PORT=8083
RESUME_SERVICE_PORT=8084
FRONTEND_PORT=3000

# Spring Boot Actuator 健康检查路径
ACTUATOR_HEALTH_PATH=/actuator/health